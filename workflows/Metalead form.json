        "jsCode": "const profile = $json.profile || {};\nconst company = profile.company?.[0];\n\n// get latest raw_event\nconst rawEvents = $json.raw_events || [];\nconst latestEvent = rawEvents[rawEvents.length - 1] || {};\n\n// extract utm from event\nconst utm = latestEvent.utm || {};\n\nconst customer = {\n  name: profile.name || profile.mobile,\n  phoneNumber: profile.mobile,\n  email: profile.email || \"\",\n};\n\n// ✅ Only add company if name exists\nif (company?.name && company.name.trim() !== \"\") {\n  customer.company = {\n    name: company.name,\n    address: {\n      street: company.address?.street || \"\",\n      city: company.address?.city || \"\",\n      state: company.address?.state || \"\",\n      country: company.address?.country || \"India\",\n      pincode: company.address?.pincode || \"\",\n    },\n  };\n}\n\nreturn {\n  customer,\n\n  // notes\n  notes:\n    latestEvent?.payload?.data?.['what_type_of_business_do_you_operate?'] || \"\",\n\n  processName: $env.RUNO_RM_PROCESS_NAME,\n  assignedTo: $env.RUNO_KUMAR_ASSIGNED_TO,\n  ruleName: $env.LEAD_RULE,\n\n  userFields: [\n    { name: \"Status\", value: \"New Lead\" },\n    { name: \"Source\", value: \"Meta - Lead Form - CC\" },\n    { name: \"Type Of Loan\", value: \"Credit Card\" },\n\n    // Correct UTM mapping\n    { name: \"Utm_source\", value: utm.utm_source || \"\" },\n    { name: \"Utm_medium\", value: utm.utm_medium || \"\" },\n    { name: \"Utm_campaign\", value: utm.utm_campaign || \"\" },\n    { name: \"Utm_term\", value: utm.utm_term || \"\" },\n    { name: \"Utm_content\", value: utm.utm_content || \"\" },\n  ]\n};"
