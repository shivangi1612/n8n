      "parameters": {
        "jsCode": "// ===================== HELPERS =====================\nconst normalize = v => (v ?? \"\").toString().trim();\nconst isEmpty = v => normalize(v) === \"\";\nconst now = () => new Date().toISOString();\n\n// ===================== INPUTS =====================\nconst existing = $input.first().json;\nconst incoming = $('Code in JavaScript16').first().json || {};\nconst lead = incoming.data || {};\n\n// ===================== PROFILE =====================\nconst profile = existing.profile ?? (existing.profile = {});\nprofile.company = Array.isArray(profile.company) ? profile.company : [];\n\n// ---------- Name ----------\nif (isEmpty(profile.name) && !isEmpty(lead.first_name)) {\n  profile.name = normalize(lead.first_name);\n}\n\nif (\n  !isEmpty(profile.name) &&\n  !isEmpty(lead.first_name) &&\n  normalize(profile.name) !== normalize(lead.first_name) &&\n  isEmpty(profile.alternate_name)\n) {\n  profile.alternate_name = normalize(lead.first_name);\n}\n\n// ---------- Mobile ----------\nif (isEmpty(profile.mobile) && !isEmpty(lead.mobile)) {\n  profile.mobile = normalize(lead.mobile);\n}\n\nif (isEmpty(profile.formatted_mobile) && !isEmpty(lead.formatted_mobile)) {\n  profile.formatted_mobile = normalize(lead.formatted_mobile);\n}\n\n// ---------- Email ----------\nif (isEmpty(profile.email) && !isEmpty(lead.email)) {\n  profile.email = normalize(lead.email);\n}\n\n// ===================== COMPANY =====================\nconst leadCompanyName = normalize(lead.company_name);\nconst leadDocs = {\n  gstin: normalize(lead.gst),\n  pan: normalize(lead.pan),\n  udyam: normalize(lead.udyam),\n};\n\n// Address from lead\nconst leadAddress = {\n  street: normalize(lead.street),\n  city: normalize(lead.city),\n  state: normalize(lead.state),\n  country: normalize(lead.country),\n  pincode: normalize(lead.pincode),\n};\n\nconst companies = profile.company;\n\n// ---------- Helpers ----------\nconst isCompanyEmpty = c =>\n  isEmpty(c.name) &&\n  isEmpty(c.gstin) &&\n  isEmpty(c.pan) &&\n  isEmpty(c.udyam);\n\n// ---------- Find company ----------\nlet company = null;\n\n// Case 1: single empty company\nconst emptyCompanies = companies.filter(isCompanyEmpty);\nif (companies.length === 1 && emptyCompanies.length === 1) {\n  company = emptyCompanies[0];\n}\n\n// Case 2: match by name\nif (!company && leadCompanyName) {\n  company = companies.find(c => normalize(c.name) === leadCompanyName);\n}\n\n// Case 3: match by identifier\nif (!company) {\n  company = companies.find(c =>\n    [\"gstin\", \"pan\", \"udyam\"].some(\n      k => !isEmpty(c[k]) && normalize(c[k]) === normalize(leadDocs[k])\n    )\n  );\n}\n\n// ---------- Create if missing ----------\nconst hasCompanyData =\n  leadCompanyName ||\n  leadDocs.gstin ||\n  leadDocs.pan ||\n  leadDocs.udyam;\n\nif (!company && hasCompanyData) {\n  company = {\n    name: leadCompanyName,\n    gstin: \"\",\n    pan: \"\",\n    udyam: \"\",\n    address: {\n      street: \"\",\n      city: \"\",\n      state: \"\",\n      country: \"\",\n      pincode: \"\",\n    },\n  };\n  companies.push(company);\n}\n\n// ---------- Fill identifiers ----------\nif (company) {\n  [\"gstin\", \"pan\", \"udyam\"].forEach(k => {\n    if (isEmpty(company[k]) && !isEmpty(leadDocs[k])) {\n      company[k] = leadDocs[k];\n    }\n  });\n\n  // ---------- Fill address (field-level merge) ----------\n  Object.keys(leadAddress).forEach(k => {\n    if (\n      isEmpty(company.address?.[k]) &&\n      !isEmpty(leadAddress[k])\n    ) {\n      company.address[k] = leadAddress[k];\n    }\n  });\n}\n\n// ===================== RAW EVENTS =====================\nexisting.raw_events = Array.isArray(existing.raw_events)\n  ? existing.raw_events\n  : [];\n\n// ✅ extract utm (from incoming OR fallback to existing top-level)\nconst utm =\n  incoming.utm ||\n  existing.utm || // fallback for old records\n  {};\n\n// ✅ push new event WITH utm\nexisting.raw_events.push({\n  data_source_system: \"Meta\",\n  lead_source: \"Meta - Lead Form\",\n  received_at: now(),\n  payload: incoming,\n  utm: utm,\n});\n\ndelete existing.utm;\n// ===================== METADATA =====================\nexisting.metadata = existing.metadata || {};\nexisting.metadata.updated_at = now();\nexisting.metadata.updated_by = \"system\";\n\n// ===================== OUTPUT =====================\n\nreturn [{ json: existing }];"
      },
