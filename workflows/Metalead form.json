        "jsCode": "const mobileNumbers = [];\nconst names = [];\n\nfor (const item of $input.all()) {\n  const customer = item.json.customer;\n\n  if (customer?.phoneNumber) {\n    let phone = customer.phoneNumber.toString().trim();\n\n    // Add 91 only if not already present\n    if (!phone.startsWith(\"91\")) {\n      phone = \"91\" + phone;\n    }\n\n    mobileNumbers.push(phone);\n\n  }\n\n  if (customer?.name) {\n    names.push(customer.name);\n  }\n}\n\nreturn [\n  {\n    json: {\n      mobiles: mobileNumbers,\n      names: names\n    }\n  }\n];"
